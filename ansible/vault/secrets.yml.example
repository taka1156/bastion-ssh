# ansible/vault/secrets.yml.example
#
# Sample secrets file managed by Ansible Vault.
# Create the actual file with:
#   ansible-vault create ansible/vault/secrets.yml
#
# Then run make setup-ansible with one of the following options:
#   make setup-ansible ARGS="--ask-vault-pass"
#   make setup-ansible ARGS="--vault-password-file /path/to/.vault_pass"
#
# Note: CF_TUNNEL_TOKEN in .env takes precedence over Vault.
#       Remove CF_TUNNEL_TOKEN from .env to manage it exclusively via Vault.

cf_tunnel_token: "YOUR_CLOUDFLARE_TUNNEL_TOKEN_HERE"
